# PostgreSQL (dev)
DB_PASSWORD=your_secure_password_here
DB_USER=postgres
DB_NAME=photographer
DB_PORT=5430

# PostgreSQL (prod)
DB_PROD_PASSWORD=your_secure_prod_password_here
DB_PROD_USER=postgres
