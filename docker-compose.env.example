# PostgreSQL (dev)
DB_PASSWORD=your_secure_password_here
DB_USER=postgres
DB_NAME=photographer
DB_PORT=5430

# PostgreSQL (prod)
DB_PROD_PASSWORD=your_secure_prod_password_here
DB_PROD_USER=postgres
DB_PROD_NAME=photographer
DB_PROD_PORT=5431

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=your_very_long_random_secret_key_here_min_32_chars

# Server
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# S3 (for original photo storage)
S3_ENDPOINT=https://your-s3-endpoint.example.com
S3_REGION=ru-1
S3_ACCESS_KEY_ID=your_access_key_here
S3_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=your_bucket_name_here